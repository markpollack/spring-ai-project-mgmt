# GitHub Issues Collection Configuration
# Source this file or export these variables before running the collection script

# ==============================================================================
# COLLECTION SETTINGS
# ==============================================================================

# Number of issues to include in each batch file
# Larger batches = fewer files, but larger individual files
# Smaller batches = more files, but easier to process
export ISSUE_BATCH_SIZE=100

# Maximum number of retry attempts for failed API calls
export ISSUE_MAX_RETRIES=3

# Delay in seconds between retry attempts
export ISSUE_RETRY_DELAY=5

# ==============================================================================
# SMART BATCHING THRESHOLDS
# ==============================================================================

# Number of comments threshold for moving issues to individual files
# Issues with more comments than this will be saved separately
export ISSUE_LARGE_THRESHOLD=50

# File size threshold in bytes for moving issues to individual files
# Issues larger than this will be saved separately (100KB default)
export ISSUE_SIZE_THRESHOLD=102400

# ==============================================================================
# ANALYSIS PREPARATION SETTINGS
# ==============================================================================

# Output directory for analysis-ready data
export ANALYSIS_OUTPUT_DIR="issues/analysis"

# Raw data directory (where collection script saves data)
export ANALYSIS_RAW_DIR="issues/raw/closed"

# ==============================================================================
# REPOSITORY SETTINGS
# ==============================================================================

# Default repository (can be overridden with --repo flag)
# Format: owner/repository
# export GITHUB_REPO="spring-projects/spring-ai"

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================

# Enable compression for output files (saves disk space)
# Set to 'true' to enable gzip compression
# export ENABLE_COMPRESSION=false

# Minimum issue body size in characters to include in analysis
# Smaller issues will be skipped during analysis preparation
# export MIN_ISSUE_SIZE=0

# ==============================================================================
# EXAMPLES
# ==============================================================================

# High-performance collection (large batches, minimal retries)
# export ISSUE_BATCH_SIZE=200
# export ISSUE_MAX_RETRIES=2
# export ISSUE_RETRY_DELAY=3

# Conservative collection (small batches, more retries)
# export ISSUE_BATCH_SIZE=50
# export ISSUE_MAX_RETRIES=5
# export ISSUE_RETRY_DELAY=10

# Memory-efficient collection (aggressive individual file threshold)
# export ISSUE_LARGE_THRESHOLD=25
# export ISSUE_SIZE_THRESHOLD=51200

# Analysis-focused collection (skip small issues)
# export MIN_ISSUE_SIZE=100