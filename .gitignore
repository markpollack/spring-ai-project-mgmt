# Compiled class file
*.class

# Maven build artifacts
target/

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# GitHub Issues Collector output files
scripts/issues/
scripts/logs/
scripts/issues-compressed/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# PR Review workflow - cloned repositories
pr-review/spring-ai/

# PR Review workflow - generated files that should be ignored
pr-review/.build_cache_pr_*
pr-review/reports/
pr-review/plans/plan-pr-*.md
pr-review/plans/enhanced-plan-pr-*.md
pr-review/logs/
pr-review/context/pr-*/ai-risk-assessment.json
pr-review/context/pr-*/ai-conversation-analysis.json
pr-review/context/pr-*/solution-assessment.json
pr-review/runs/

# PR Review workflow - persistent state files
pr-review/state/pr-branch-mapping.json

# Release workflow - generated files and working directories
release/logs/
release/state/
release/spring-ai-release/

# Git squash merge tool - working directories (timestamped)
release/spring-ai-squash-merge-*/

# Contributors output
release/contributors-output/

# IDE files
pr-review/.idea/
.idea/
